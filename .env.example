# DapplePot SDK is configured in code — no env vars required.
#
# Example:
#   import dapplepot_sdk as dp
#   client = dp.DapplePot(
#       sdk_key   = "dp_sk_...",
#       tenant_id = "your-tenant-id",
#       agent_id  = "your-agent-id",
#       ingest_url = "http://localhost:3000",   # optional, default: http://localhost:3000
#   )
#
# Online checks and their action types (alert / block_call / terminate_session / sanitize)
# are fetched automatically from the API at startup — configure them in the DapplePot UI.

# Provider API keys — only needed for local agent test fixtures
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
